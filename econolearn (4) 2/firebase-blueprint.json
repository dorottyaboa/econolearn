{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's photo URL" },
        "xp": { "type": "integer", "description": "Total experience points" },
        "streak": { "type": "integer", "description": "Current daily streak" },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "List of earned badge IDs" },
        "completedNodes": { "type": "array", "items": { "type": "string" }, "description": "List of completed lesson node IDs" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last time the profile was updated" }
      },
      "required": ["uid", "displayName", "xp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles for leaderboard and progress tracking"
    }
  }
}
