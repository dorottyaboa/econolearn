rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - displayName: string (required) - User's display name
    //   - photoURL: string (optional) - User's photo URL
    //   - xp: number (required) - Total experience points
    //   - streak: number (optional) - Current daily streak
    //   - badges: list (optional) - List of earned badge IDs
    //   - completedNodes: list (optional) - List of completed lesson node IDs
    //   - lastUpdated: timestamp (optional) - Last update time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'xp']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.xp is number && data.xp >= 0 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!('streak' in data) || data.streak is number) &&
             (!('badges' in data) || data.badges is list) &&
             (!('completedNodes' in data) || data.completedNodes is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow anyone authenticated to read user profiles for the leaderboard
      // Note: We only expose non-sensitive fields in our assumed model
      allow read: if isAuthenticated();
      
      // Users can only create/update their own profile
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      // No one can delete profiles for now
      allow delete: if false;
    }
  }
}
